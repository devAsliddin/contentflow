# ─────────────────────────────────────────────────────────────────────────────
# ContentFlow — Environment Variables
# Copy this file to .env and fill in all required values.
#
# Generate SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Generate ENCRYPTION_KEY:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-32-char-random-hex-string
ENCRYPTION_KEY=change-this-to-a-fernet-base64-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=contentflow
POSTGRES_PASSWORD=change-this-strong-db-password
POSTGRES_DB=contentflow
DATABASE_URL=postgresql+asyncpg://contentflow:change-this-strong-db-password@postgres:5432/contentflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS — comma-separated list of allowed origins ───────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Media storage ─────────────────────────────────────────────────────────────
MEDIA_DIR=/app/media

# ── AI — Anthropic Claude ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── AI — Ollama (optional local LLM) ─────────────────────────────────────────
# Leave as default if running Ollama on the host machine
OLLAMA_URL=http://host.docker.internal:11434

# ── AI — OpenRouter (optional fallback) ──────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ── Instagram / Facebook ──────────────────────────────────────────────────────
# Create an app at: https://developers.facebook.com
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── TikTok ────────────────────────────────────────────────────────────────────
# Create an app at: https://developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── LinkedIn ─────────────────────────────────────────────────────────────────
# Create an app at: https://www.linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── YouTube ──────────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── X (Twitter) ───────────────────────────────────────────────────────────────
# Create an app at: https://developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
