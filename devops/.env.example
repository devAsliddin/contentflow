# ─────────────────────────────────────────────────────────────────────────────
# ContentFlow DevOps — SSH Credentials
# Copy to: devops/.env   (never commit this file)
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend server ────────────────────────────────────────────────────────────
BACKEND_SSH=root@123.456.789.10
BACKEND_SSH_PASSWORD=your_backend_password_here

# ── Frontend server (can be the same IP as backend) ──────────────────────────
FRONTEND_SSH=root@123.456.789.11
FRONTEND_SSH_PASSWORD=your_frontend_password_here

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=contentflow.uz
EMAIL=admin@contentflow.uz

# ── GitHub repo ───────────────────────────────────────────────────────────────
REPO=https://github.com/devAsliddin/contentflow.git
BRANCH=main