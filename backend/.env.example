# ── Database ─────────────────────────────────────────────────────────────────
# Native VPS deploy:
DATABASE_URL=postgresql+asyncpg://contentflow:YOUR_DB_PASSWORD@localhost:5432/contentflow
# Docker deploy (set in docker-compose.yml automatically — only edit below vars):
POSTGRES_USER=contentflow
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=contentflow

REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production-min-32-chars

# Fernet key for encrypting stored credentials (REQUIRED in production).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Never rotate this key without re-encrypting all credentials first.
ENCRYPTION_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: http://localhost:5173
# Production:  https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Instagram ─────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── TikTok ────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Facebook ──────────────────────────────────────────────────────────────────
# https://developers.facebook.com/apps/ → Settings → Basic
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# https://www.linkedin.com/developers/apps → Auth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── YouTube (Google OAuth 2.0) ────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── X / Twitter ───────────────────────────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard
# For OAuth 2.0 PKCE: use Client ID as TWITTER_API_KEY, Client Secret as TWITTER_API_SECRET
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
# development | production
ENVIRONMENT=production

FRONTEND_URL=https://app.yourdomain.com
BACKEND_URL=https://app.yourdomain.com

# Absolute path to media upload directory
MEDIA_DIR=/var/www/contentflow/media
